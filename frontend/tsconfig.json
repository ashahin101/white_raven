{
  "include": [
    "**/*",
    "**/.server/**/*",
    "**/.client/**/*",
    ".react-router/types/**/*",
    "../packages/shared"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "jsx": "react-jsx",
    "rootDirs": ["../"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "@shared/*": ["../packages/shared/*"]
    },
    "composite": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  },
  "references": [{ "path": "../packages/shared" }]
}
